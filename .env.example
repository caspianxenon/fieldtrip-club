# Field Trip Club - Environment Configuration
# Copy this file to .env and fill in your actual values
# DO NOT COMMIT .env FILE TO VERSION CONTROL!

# ========== SERVER CONFIGURATION ==========
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ========== EMAIL CONFIGURATION (OTP) ==========
# Using Gmail
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_16chars
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# ========== DATABASE CONFIGURATION ==========
# Choose ONE: Firebase OR MongoDB

# --- Option 1: Firebase (Recommended for beginners) ---
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com

# --- Option 2: MongoDB ---
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/fieldtrip

# ========== AUTHENTICATION ==========
JWT_SECRET=change_me_to_at_least_32_characters_minimum_please_thank_you

# ========== KYC VERIFICATION (Placeholder) ==========
# Replace with real KYC provider API
# Providers: Smile ID, AuthentiAfrica, SafetyRx, etc.
KYC_API_KEY=placeholder_get_from_kyc_provider
KYC_API_URL=https://sandbox.api.example.com/kyc

# ========== MPESA PAYMENT (Placeholder) ==========
# Get from Safaricom Daraja API (https://developer.safaricom.co.ke/)
MPESA_TILL_NUMBER=your_till_number_for_testing
MPESA_API_KEY=placeholder_daraja_api_key
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_PASSKEY=your_passkey
MPESA_SANDBOX_URL=https://sandbox.safaricom.co.ke/api
